<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/nlog-internal.log">

  <extensions>
    <add assembly="NLog.Web.AspNetCore" />
    <add assembly="NLog.Targets.Network" />
  </extensions>

  <variable name="applicationName" value="OrderCore.Api" />
  <variable name="standardLayout" value="${var:applicationName}|${longdate}|${event-properties:item=EventId_Id}|${uppercase:${level}}|${logger}|${message} ${exception:format=tostring}" />

  <targets async="true">
    <target xsi:type="Console"
            name="console"
            layout="${var:standardLayout}" />

    <target xsi:type="File"
            name="file"
            fileName="${basedir}/logs/ordercore-api-${shortdate}.log"
            archiveFileName="${basedir}/logs/archive/ordercore-api-${shortdate}.{#}.log"
            archiveAboveSize="10485760"
            archiveNumbering="Sequence"
            maxArchiveFiles="14"
            keepFileOpen="false"
            layout="${var:standardLayout}" />

    <target xsi:type="Chainsaw"
            name="network"
            address="${environment:variable=ORDERCORE_LOG_NETWORK_ADDRESS:default=udp4\://127.0.0.1\:9998}"
            appInfo="${var:applicationName}"
            layout="${var:standardLayout}" />
  </targets>

  <rules>
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.*" maxlevel="Info" final="true" />
    <logger name="*" minlevel="Info" writeTo="console,file" />
    <logger name="*" minlevel="Debug" writeTo="network">
      <filters defaultAction="Log">
        <when condition="'${environment:variable=ORDERCORE_LOG_NETWORK_ENABLED}' != 'true'" action="Ignore" />
      </filters>
    </logger>
  </rules>
</nlog>
