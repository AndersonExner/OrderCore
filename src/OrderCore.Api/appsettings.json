{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Outbox": {
    "Enabled": true,
    "PollingIntervalSeconds": 10,
    "BatchSize": 20,
    "MaxRetryCount": 5
  },
  "Messaging": {
    "OutboxPublisher": "Logging"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "ordercore",
    "Password": "ordercore",
    "VirtualHost": "/",
    "ExchangeName": "ordercore.events",
    "ExchangeType": "topic",
    "OrderPaidQueueName": "ordercore.order-paid",
    "DeclareTopology": true
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=ordercore;Username=postgres;Password=postgres"
  }
}
